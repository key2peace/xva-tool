import os
import sys
import tarfile
import hashlib
import shutil
import argparse
import time

def calculate_sha256(file_path):
	"""
	Calculates an immutable SHA-256 checksum block of a target script file
	to maintain cryptographic and forensic integrity bounds during installation.
	"""
	sha256 = hashlib.sha256()
	try:
		with open(file_path, 'rb') as f:
			while True:
				chunk = f.read(65536) # 64KB RAM streaming blocks evaluation
				if not chunk:
					break
				sha256.update(chunk)
		return sha256.hexdigest()
	except (IOError, OSError):
		return None


def handle_init(args):
	"""Generates a perfectly pre-formatted enterprise plugin skeleton layout."""
	target_dir = args.plugin_dir
	plugin_name = os.path.basename(os.path.abspath(target_dir)).lower()
	
	if os.path.exists(target_dir):
		sys.stderr.write("Error: Target directory '" + target_dir + "' already exists.\n")
		sys.exit(1)

	print "Initializing plugin development environment template for: " + plugin_name.upper()

	# Create standard plugin repository subdirectory layers
	os.makedirs(target_dir)
	os.makedirs(os.path.join(target_dir, "docs"))

	# 1. Generate core plugin engine code skeleton (module.py)
	module_code = (
		"#!/usr/bin/python\n# -*- coding: utf-8 -*-\n"
		"# ==============================================================================\n"
		"#  XVAPLUGIN - " + plugin_name.upper() + " Extension Adapter\n"
		"# ==============================================================================\n"
		"#  Copyright (c) 2026 Alexander Maassen <outsider@cuci.nl>\n"
		"#  Licensed under the terms of the MIT License\n"
		"# ==============================================================================\n"
		'"""\n' + plugin_name.upper() + " extension module description documentation string layer.\n"
		'"""\n\n'
		"def is_supported():\n"
		"\t\"\"\"Self-verification routine check. Verify required system commands or libraries here.\"\"\"\n"
		"\treturn True\n\n"
		"def register_arguments(parser):\n"
		"\t\"\"\"Attach domain specific argument flags here if needed.\"\"\"\n"
		"\tpass\n\n"
		"def execute(args):\n"
		"\t\"\"\"Main orchestration lifecycle entrypoint execution block.\"\"\"\n"
		"\tprint \"Executing " + plugin_name + " module execution context pipeline.\"\n"
	)
	with open(os.path.join(target_dir, "module.py"), "w") as f:
		f.write(module_code)

	# 2. Generate configuration template block (config.conf)
	with open(os.path.join(target_dir, "config.conf"), "w") as f:
		f.write("[" + plugin_name + "]\n# Configure framework module properties here\nenabled = True\n")

	# 3. Generate documentation asset layer (docs/readme.md)
	with open(os.path.join(target_dir, "docs", "readme.md"), "w") as f:
		f.write("# " + plugin_name.upper() + " Plugin Manual\nDocument usage patterns and target instructions here.\n")

	print "Success: Enterprise development framework provisioned safely inside: " + target_dir


def handle_build(args):
	"""
	Scans the development environment, computes an immutable SHA-256 hash of the 
	code block, embeds metadata, and compiles the bundle into an encrypted package.
	"""
	src_dir = args.plugin_dir
	if not os.path.exists(src_dir) or not os.path.isdir(src_dir):
		sys.stderr.write("Error: Source plugin development folder does not exist.\n")
		sys.exit(1)

	plugin_name = os.path.basename(os.path.abspath(src_dir)).lower()
	module_file = os.path.join(src_dir, "module.py")
	config_file = os.path.join(src_dir, "config.conf")

	if not os.path.exists(module_file):
		sys.stderr.write("Error: Critical infrastructure file 'module.py' is missing from root.\n")
		sys.exit(1)

	# Cryptographic fingerprinting phase: Calculate the active SHA-256 payload checksum
	print "Computing cryptographic validation checksum block via SHA-256..."
	checksum = calculate_sha256(module_file)
	if not checksum:
		sys.stderr.write("Error: Failed to compute cryptographic checksum payload.\n")
		sys.exit(1)
	
	# Generate a localized runtime meta manifest block file on the fly
	manifest_file = os.path.join(src_dir, "manifest.meta")
	with open(manifest_file, "w") as f:
		f.write("[manifest]\n")
		f.write("name = " + plugin_name + "\n")
		f.write("checksum_sha256 = " + checksum + "\n")
		f.write("compiled_by = Alexander Maassen\n")

	output_tarname = plugin_name + ".tar.gz"
	print "Compiling production deployment distribution envelope: " + output_tarname

	# Build and compress the target tarball cleanly
	try:
		with tarfile.open(output_tarname, "w:gz") as tar:
			tar.add(module_file, arcname="module.py")
			if os.path.exists(config_file):
				tar.add(config_file, arcname="config.conf")
			tar.add(manifest_file, arcname="manifest.meta")
			
			# Include relative documentation layers recursively into the package space
			docs_path = os.path.join(src_dir, "docs")
			if os.path.exists(docs_path):
				tar.add(docs_path, arcname="docs")
		print "Success: Cryptographically signed plugin ready for release deployment loops."
	except Exception as e:
		sys.stderr.write("Error: Packaging transaction failed: " + str(e) + "\n")
	finally:
		# Always clean up the temporary manifest artifact from the development space
		if os.path.exists(manifest_file):
			os.remove(manifest_file)


def main():
	parser = argparse.ArgumentParser(description="XVATOOL Enterprise Package & Plugin Compilation Suite")
	subparsers = parser.add_subparsers(dest="command", help="Developer actions")

	# Subcommand: init
	p_init = subparsers.add_parser("init", help="Bootstrap a clean new pluggable module extension directory structure")
	p_init.add_argument("plugin_dir", help="Target path directory destination to create")
	p_init.set_defaults(func=handle_init)

	# Subcommand: build
	p_build = subparsers.add_parser("build", help="Hash and compile a development plugin directory into a distributable tarball")
	p_build.add_argument("plugin_dir", help="Path to the active plugin development source folder")
	p_build.set_defaults(func=handle_build)

	args = parser.parse_args()
	if args.command:
		args.func(args)
	else:
		parser.print_help()

if __name__ == "__main__":
	main()
