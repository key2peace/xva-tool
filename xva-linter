#!/usr/bin/env python3
import os
import re

TARGET_EXTENSIONS = ('.py', '.spec', '.conf', '.md')
EXCLUDE_DIRS = ('.git',)

def generate_header(file_path):
	return """# ==============================================================================
#      XVA-TOOL - Forensics & Recovery Tool designed for XenServer
#
#      copyright ©2026 Alexander Maassen & Gemini AI
#      Distributed under the terms of the MIT License.
# ==============================================================================
"""

def fix_file_layout(file_path):
	# Voorkom dat het script zichzelf gaat linten
	if os.path.basename(file_path) == 'xva-linter':
		return

	with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
		content = f.read()

	content = content.replace('\r\n', '\n')
	lines = content.split('\n')
	fixed_lines = []
	
	for line in lines:
		# 2. Regex match: Vervang groepen van 8 spaties aan het begin van de regel door een tab.
		# Dit herhaalt zich voor geneste niveaus (16, 24, etc.) maar raakt de strings binnenin NOOIT.
		while re.match(r'^\t*        ', line):
			line = re.sub(r'^(\t*)        ', r'\1\t', line)
			
		if line.strip() == '':
			line = ''
		else:
			# Voorkom het slopen van markdown-tabellen en regeleinde-literal-padding
			if file_path.endswith('.md') or file_path.endswith('.py'):
				# Bij .py bestanden beschermen we hiermee ook trailing spaces binnen string literals
				# We strippen alleen de absolute, dode whitespace aan het einde van de regel (\r\n\t )
				line = line.rstrip('\r\n\t ')
			else:
				line = line.rstrip()
				
		fixed_lines.append(line)

	fixed_content = '\n'.join(fixed_lines)
	
	if file_path.endswith('.py') and "Alexander Maassen" not in fixed_content:
		fixed_content = generate_header(file_path) + fixed_content.lstrip()

	fixed_content = fixed_content.rstrip() + '\n'

	if content != fixed_content:
		with open(file_path, 'w', encoding='utf-8') as f:
			f.write(fixed_content)
		print(f"[FIXED] Layout alignment completed: {file_path}")

def execute_repository_scan():
	current_script = os.path.abspath(__file__)
	for root, dirs, files in os.walk('.'):
		dirs[:] = [d for d in dirs if d not in EXCLUDE_DIRS]
		for file in files:
			file_path = os.path.join(root, file)
			# Controleer extensie OF dat het dit specifieke uitvoerbare script zelf is
			if file.endswith(TARGET_EXTENSIONS) or os.path.abspath(file_path) == current_script:
				fix_file_layout(file_path)

if __name__ == "__main__":
	print("[*] Launching xva-tool Layout Linter & Fixer...")
	execute_repository_scan()
	print("[+] Repository style compliance unified successfully.")
