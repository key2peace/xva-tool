def format_size(size_in_bytes):
	"""Formats byte constraints into human-readable industrial strings."""
	for unit in ['B', 'KB', 'MB', 'GB', 'TB']:
		if size_in_bytes < 1024.0:
			return "{:.2f} {}".format(size_in_bytes, unit)
		size_in_bytes /= 1024.0
	return "{:.2f} PB".format(size_in_bytes)


def log_message(level, message, quiet_flag=False):
	"""Centralized framework logging system. Routes outputs to files and tracking consoles."""
	if quiet_flag and level.lower() not in ["critical", "error"]:
		return
	timestamp = time.strftime("%Y-%m-%d %H:%M:%S")
	prefix = "[{}] [{}] ".format(timestamp, level.upper())
	
	if level.lower() in ["critical", "error"]:
		sys.stderr.write(COLOR_RED + prefix + message + COLOR_RESET + "\n")
	else:
		sys.stdout.write(prefix + message + "\n")


