			handle_enable_plugin(args)
		elif args.plugin_action == "disable":
			handle_disable_plugin(args)
			
	elif args.subcommand in plugin_commands_map:
		# Dynamic dispatch execution block pass straight to the loaded command hook plugin module
		try:
