	p_dis.add_argument("plugin_path", help="Category and name block token sequence (e.g., storage/nfs)")

	# 2. DYNAMIC REGISTRATION RING: Scan and hook third-party command plugins live into argparse
	active_plugins = scan_available_plugins()
	plugin_commands_map = {}

	for pl in active_plugins:
		if pl["category"] == "commands":
			cmd_name = pl["name"]
			# Allocate a dynamic new sub-parser handle on behalf of the discovered extension module
			p_custom = subparsers.add_parser(cmd_name, help=pl["help"])
			
			# Add standard archive/target arguments automatically if required by the workflow
			p_custom.add_argument("archive", nargs="?", help="Source context file descriptor location")
			p_custom.add_argument("target", nargs="?", help="Output target context destination")
			
			# Allow the command plugin to register its own specific execution flags matrix
			if hasattr(pl["module"], "register_arguments"):
				pl["module"].register_arguments(p_custom)
				
			plugin_commands_map[cmd_name] = pl["module"]

	# Evaluate active interactive TUI routing parameters bounds
	if len(sys.argv) == 1 and sys.stdout.isatty():
